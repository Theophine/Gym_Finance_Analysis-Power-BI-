table Metrics
	lineageTag: 2fa390a0-df15-46bc-80ca-0cb0eca296c0

	measure TotalAmount = SUM(revenue_expense[Amount_])
		formatString: 0
		displayFolder: General Metrics
		lineageTag: 1b723d0a-b5c6-49fd-8b55-a4aeba2b1937

	measure TotalRevenue = CALCULATE([TotalAmount], revenue_expense[Revenue_or_expense] = "Revenue")
		formatString: 0.00
		displayFolder: Revenue
		lineageTag: 3c5c0a8b-2984-4495-b9fc-0652d3725edf

	measure TotalExpense = CALCULATE([TotalAmount], revenue_expense[Revenue_or_expense] = "Expense")
		formatString: 0.00
		displayFolder: Expenses
		lineageTag: dcd70a54-2901-461a-a282-bb763fa141e4

	measure Revenue_PM = CALCULATE([TotalRevenue], DATEADD('Date'[Date], -1, MONTH))
		formatString: 0.00
		displayFolder: Revenue
		lineageTag: 14bcee69-5a80-4714-87c6-941deccab9d6

	measure Revenue_MoM = ```
			
			
			    var Month_Diff = [TotalRevenue] - [Revenue_PM]
			    var Result = DIVIDE(Month_Diff, [Revenue_PM])
			
			    return 
			        SWITCH(TRUE(), 
			            Result = BLANK(),"--", 
			            FORMAT(Result, "0.00%")
			)
			```
		displayFolder: Revenue
		lineageTag: 8fc5bec9-9e52-48ca-a1d9-ea391b81863a

	measure Revenue_CF = ```
			
			
			    var Month_Diff = [TotalRevenue] - [Revenue_PM]
			    var Result = DIVIDE(Month_Diff, [Revenue_PM])
			
			    return 
			        if(Result > 0, "Green", "Red")
			
			```
		displayFolder: Revenue
		lineageTag: 4845cb5c-6126-4bb7-8dad-9275a7394788

	measure Expense_PM = CALCULATE([TotalExpense], DATEADD('Date'[Date], -1, MONTH))
		formatString: 0.00
		displayFolder: Expenses
		lineageTag: 8e97d25a-8896-4bdc-a7bf-96876affb97e

	measure Expense_MoM = ```
			
			
			    var Month_Diff = [TotalExpense] - [Expense_PM]
			    var Result = DIVIDE(Month_Diff, [Expense_PM])
			
			    return 
			        SWITCH(TRUE(), 
			            Result = BLANK(),"--", 
			            FORMAT(Result, "0.00%")
			) 
			
			```
		displayFolder: Expenses
		lineageTag: 71c6d682-8002-425b-bfc9-2f3604ed179d

	measure Expense_CF = ```
			
			
			    var Month_Diff = [TotalExpense] - [Expense_PM]
			    var Result = DIVIDE(Month_Diff, [Expense_PM])
			
			    return 
			        if(Result < 0, "Green", "Red")
			
			```
		displayFolder: Expenses
		lineageTag: 6a88c968-2fe8-4a1e-87ec-1ab207033cda

	measure COGS = CALCULATE([TotalAmount], revenue_expense[Revenue_Expense_Group] = "COGS")
		formatString: 0
		displayFolder: General Metrics
		lineageTag: 5356084a-1efa-4860-be3e-421aa2ce1067

	measure GrossProfit = [TotalRevenue] - [COGS]
		formatString: 0.00
		displayFolder: GrossProfit
		lineageTag: 0c39837a-bede-4577-8080-7c4fd5914cb6

	measure GrossProfit_Margin = ```
			
			    DIVIDE([GrossProfit], [TotalRevenue])
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: GrossProfit
		lineageTag: 798485e4-5f03-46ca-82a5-a93fdf645c8f

	measure GrossProfit_PM = CALCULATE([GrossProfit], DATEADD('Date'[Date], -1, MONTH))
