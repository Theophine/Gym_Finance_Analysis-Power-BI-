		lineageTag: c6bc8595-b996-4551-86e0-f6a5d06b07b8

	measure GrossProfit_MoM = ```
			
			
			    var Month_Diff = [GrossProfit] - [GrossProfit_PM]
			    var Result = DIVIDE(Month_Diff, [GrossProfit_PM])
			
			    return 
			        SWITCH(TRUE(), 
			            Result = BLANK(),"--", 
